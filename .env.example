# Copy to .env.local (gitignored) for local dev, and set in Vercel project env for prod.

# Amazon Associates tag — the ONLY thing needed to turn on affiliate revenue.
# Get it from https://affiliate-program.amazon.com (Jeff/DSG account). Until set,
# "Buy →" links work but earn no commission.
VITE_AFFILIATE_TAG=

# Stripe publishable key (client-safe) — for the future Pro Plan checkout.
# The SECRET key never goes here; it lives only in the serverless function/vault.
VITE_STRIPE_PK=
