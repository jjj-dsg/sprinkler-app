# Copy to .env.local (gitignored) for local dev, and set in Vercel project env for prod.

# ── Affiliate Revenue (Path 1) ────────────────────────────────────────────────
# Amazon Associates tag — the ONLY thing needed to turn on affiliate revenue.
# Get from https://affiliate-program.amazon.com (Jeff/DSG account). Until set,
# "Buy →" links work but earn no commission.
VITE_AFFILIATE_TAG=

# ── Stripe Pro Plan / $19 (Path 2) ───────────────────────────────────────────
# Client-side publishable key (safe to expose in browser code).
# Set this to unlock the Stripe Checkout redirect after PDF download.
VITE_STRIPE_PK=

# ── Server-side only (Vercel env vars, NEVER VITE_ prefixed) ─────────────────
# Stripe secret key — only set in Vercel project environment, never in .env files.
# STRIPE_SECRET_KEY=sk_live_…

# Stripe Price ID for the Pro Plan ($19 one-time) — create in Stripe dashboard.
# STRIPE_PRICE_ID=price_…

# PostHog analytics key — set in Vercel to activate server-side event forwarding.
# Create a free project at https://posthog.com. Not client-exposed.
# POSTHOG_API_KEY=phc_…
